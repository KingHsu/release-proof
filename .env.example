# Never commit a real key. Offline mode is the default.
RELEASE_PROOF_OFFLINE=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
RELEASE_PROOF_MAX_LLM_CALLS=6
RELEASE_PROOF_MAX_OUTPUT_TOKENS=1800
RELEASE_PROOF_DATA_DIR=./runtime
# Set this for a non-editable wheel/container installation.
RELEASE_PROOF_PROJECT_ROOT=
RELEASE_PROOF_ALLOWED_ROOTS=
